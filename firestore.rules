rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Collection Group rules (Must be defined broadly for CG queries)
    match /{path=**}/requests/{reqId} {
      allow read: if isSignedIn() && (resource.data.get('uid', '') == request.auth.uid);
      allow write: if isSignedIn() && (
        (request.method == 'create' && request.resource.data.get('uid', '') == request.auth.uid) ||
        (request.method == 'update' && resource.data.get('uid', '') == request.auth.uid) ||
        (request.method == 'delete' && resource.data.get('uid', '') == request.auth.uid)
      );
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getGroupData(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }

    function isMemberOfData(data) {
      return isSignedIn() && (
        request.auth.uid == data.get('ownerId', '') || 
        request.auth.uid in data.get('members', []) || 
        request.auth.uid in data.get('deputies', [])
      );
    }

    function isMember(groupId) {
      let groupData = get(/databases/$(database)/documents/groups/$(groupId)).data;
      return isSignedIn() && (
        request.auth.uid == groupData.ownerId || 
        request.auth.uid in groupData.get('members', []) || 
        request.auth.uid in groupData.get('deputies', [])
      );
    }

    function isDeputyOrOwnerOfData(data) {
      return isSignedIn() && (
        request.auth.uid == data.get('ownerId', '') || 
        request.auth.uid in data.get('deputies', [])
      );
    }

    function isPendingOwner(data) {
      return isSignedIn() && data.get('pendingOwner', '') == request.auth.uid;
    }

    function isDeputyOrOwner(groupId) {
      return isDeputyOrOwnerOfData(getGroupData(groupId));
    }

    function isOwner(groupId) {
      return isSignedIn() && request.auth.uid == getGroupData(groupId).ownerId;
    }

    // 1. Users
    match /users/{uid} {
      allow get, list: if isSignedIn();
      allow create, update: if isUser(uid);

      match /notifications/{notifId} {
        allow read, update, delete: if isUser(uid);
        allow create: if isSignedIn(); 
      }
    }

    // 2. Groups
    match /groups/{groupId} {
      allow get: if isSignedIn(); 
      allow list: if isMemberOfData(resource.data) || 
                   (isSignedIn() && (
                    (request.auth.token.get('email', '') != '' && request.auth.token.email in resource.data.get('pendingInvites', [])) ||
                    (request.auth.token.get('phone_number', '') != '' && request.auth.token.phone_number in resource.data.get('pendingInvites', []))
                   ));
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isDeputyOrOwnerOfData(resource.data) || (
        isMemberOfData(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessageAt'])
      ) || (
        isPendingOwner(resource.data) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerId', 'pendingOwner'])
      ) || (
        // Action: Join or Accept Invite
        isSignedIn() && 
        request.resource.data.members.size() == resource.data.members.size() + 1 &&
        request.resource.data.members.hasAll(resource.data.members) &&
        request.auth.uid in request.resource.data.members &&
        (
          // Case 1: Pre-invited by string (Email/Phone)
          ((request.auth.token.get('email', '') in resource.data.get('pendingInvites', []) || 
            request.auth.token.get('phone_number', '') in resource.data.get('pendingInvites', []) ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('email', '') in resource.data.get('pendingInvites', []) ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('phoneNumber', '') in resource.data.get('pendingInvites', [])) &&
           request.resource.data.get('pendingInvites', []).size() == resource.data.get('pendingInvites', []).size() - 1 && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'pendingInvites'])) ||
          // Case 2: Invited via registered user UID
          (exists(/databases/$(database)/documents/groups/$(groupId)/requests/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/groups/$(groupId)/requests/$(request.auth.uid)).data.get('status', '') == 'invited' &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])) ||
          // Case 3: Group does not require approval
          (resource.data.get('settings', {}).get('requireApproval', true) == false && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']))
        )
      );

      // Announcements
      match /announcements/{annoId} {
        allow read: if isMember(groupId);
        allow create: if isDeputyOrOwner(groupId);
        allow update: if isDeputyOrOwner(groupId) || (isMember(groupId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'comments']));
      }

      // Campaigns
      match /campaigns/{campId} {
        allow read: if isMember(groupId);
        allow create, update: if isDeputyOrOwner(groupId);
      }

      // Transactions
      match /transactions/{txId} {
        allow read: if isMember(groupId);
        allow create: if isMember(groupId);
        allow update: if isDeputyOrOwner(groupId) || (isMember(groupId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'comments']));
        allow delete: if isDeputyOrOwner(groupId); 
      }
      
      // Requests
      match /requests/{reqId} {
        allow read: if isMember(groupId) || (isSignedIn() && resource.data.get('uid', '') == request.auth.uid);
        allow create: if isSignedIn();
        allow update, delete: if isDeputyOrOwner(groupId) || (isSignedIn() && resource.data.get('uid', '') == request.auth.uid);
      }

      // Tasks
      match /tasks/{taskId} {
        allow read: if isMember(groupId);
        allow create: if isDeputyOrOwner(groupId);
        allow update: if isDeputyOrOwner(groupId) || (
          isSignedIn() && 
          resource.data.assigneeId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        );
        allow delete: if isDeputyOrOwner(groupId);
      }

      // Polls
      match /polls/{pollId} {
        allow read: if isMember(groupId);
        allow create: if isMember(groupId) && 
                      request.resource.data.createdBy == request.auth.uid;
        allow update: if isMember(groupId) && (
          // Allow anyone to vote (updates options array)
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['options'])
        );
        allow delete: if isDeputyOrOwner(groupId) || (isSignedIn() && resource.data.createdBy == request.auth.uid);
      }

      // Messages
      match /messages/{msgId} {
        allow list: if isMember(groupId);
        allow get: if isMember(groupId);
        allow create: if isMember(groupId) && 
                      request.resource.data.senderId == request.auth.uid &&
                      request.resource.data.content is string &&
                      request.resource.data.content.size() > 0 &&
                      request.resource.data.content.size() <= 5000;
        allow update: if isMember(groupId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
        allow delete: if isMember(groupId) && (isDeputyOrOwner(groupId) || (isSignedIn() && resource.data.senderId == request.auth.uid));
      }
    }

    // Collection Group rule for invitations
    // Moved to top for clarity and simplified
  }
}
